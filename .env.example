# ═══════════════════════════════════════════
# Signal24 — Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env.local and fill in your values

# News APIs (optional — fallback headlines are used if not set)
GNEWS_API_KEY=your_gnews_api_key
CURRENTS_API_KEY=your_currents_api_key

# Chat / Betting Server
NEXT_PUBLIC_CHAT_URL=http://localhost:3001
ADMIN_KEY=signal24admin
ALLOWED_ORIGINS=http://localhost:3000
